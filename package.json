{
  "name": "enterprise-backend",
  "version": "1.0.0",
  "description": "Enterprise backend platform - Node.js + Express + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint . --ext .js --ignore-path .eslintignore",
    "test": "jest --coverage --forceExit",
    "build": "echo 'No build step required for Node.js'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
