NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/enterprise_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enterprise_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# Security
JWT_SECRET=your_jwt_secret_here

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
